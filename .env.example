# ConstWare AI Intelligence Engine - Environment Variables

# Anthropic Claude API (Mandatory for AI features)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenWeatherMap API (Optional, will fallback to mock data)
# Get your key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Next.js Port (Default 3001)
PORT=3001
