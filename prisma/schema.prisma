datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Profile {
  id                String              @id @db.Uuid
  fullName          String?             @map("full_name")
  companyName       String?             @map("company_name")
  email             String?
  phone             String?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  sites             Site[]
  blueprintAnalyses BlueprintAnalysis[]

  @@map("profiles")
}

model Site {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  location             String
  supervisor           String?
  progress             Float               @default(0)
  status               String              @default("active")
  startDate            DateTime?           @map("start_date")
  endDate              DateTime?           @map("end_date")
  description          String?
  budgetTotal          Decimal?            @map("budget_total") @db.Decimal(12, 2)
  clientName           String?             @map("client_name")
  clientPhone          String?             @map("client_phone")
  clientEmail          String?             @map("client_email")
  clientAccessId       String?             @unique @map("client_access_id")
  clientAccessEnabled  Boolean             @default(false) @map("client_access_enabled")
  clientAccessViews    Int                 @default(0) @map("client_access_views")
  clientLastAccessedAt DateTime?           @map("client_last_accessed_at")
  contractorId         String              @db.Uuid @map("contractor_id")
  contractor           Profile             @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  blueprintAnalyses    BlueprintAnalysis[]
  clientAccessLogs     ClientAccessLog[]
  siteWorkers          SiteWorker[]
  attendance           Attendance[]
  advances             Advance[]
  wages                Wage[]
  expenses             Expense[]

  @@map("sites")
}

model BlueprintAnalysis {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contractorId       String    @db.Uuid @map("contractor_id")
  contractor         Profile   @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  siteId             String    @db.Uuid @map("site_id")
  site               Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  blueprintImageUrl  String?   @map("blueprint_image_url")
  inputData          Json      @default("{}") @map("input_data")
  aiAnalysis         Json      @default("{}") @map("ai_analysis")
  interiorSelections Json      @default("{}") @map("interior_selections")
  aiInteriorReport   Json      @default("{}") @map("ai_interior_report")
  totalCivilCost     Decimal   @default(0) @map("total_civil_cost") @db.Decimal(12, 2)
  totalInteriorCost  Decimal   @default(0) @map("total_interior_cost") @db.Decimal(12, 2)
  grandTotal         Decimal   @default(0) @map("grand_total") @db.Decimal(12, 2)
  shareToken         String?   @unique @default(dbgenerated("gen_random_uuid()::text")) @map("share_token")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @map("updated_at")

  @@index([shareToken], map: "idx_blueprint_share_token")
  @@index([contractorId], map: "idx_blueprint_contractor")
  @@map("blueprint_analyses")
}

model ClientAccessLog {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId         String    @db.Uuid @map("site_id")
  site           Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  clientAccessId String    @map("client_access_id")
  accessedAt     DateTime  @default(now()) @map("accessed_at")
  ipAddress      String?   @map("ip_address")

  @@map("client_access_logs")
}

model Worker {
  id                String       @id
  name              String
  phone             String
  skill             String
  dailyWage         Decimal      @map("daily_wage") @db.Decimal(10, 2)
  assignedSiteId    String?      @map("assigned_site_id")
  rating            Decimal      @default(0) @db.Decimal(3, 2)
  kycVerified       Boolean      @default(false) @map("kyc_verified")
  aadhaarNumber     String?      @map("aadhaar_number")
  photoUrl          String?      @map("photo_url")
  completedProjects Int          @default(0) @map("completed_projects")
  reliabilityScore  Int          @default(100) @map("reliability_score")
  status            String       @default("available")
  createdAt         DateTime     @default(now()) @map("created_at")
  siteWorkers       SiteWorker[]
  attendance        Attendance[]
  advances          Advance[]
  wages             Wage[]

  @@map("workers")
}

model SiteWorker {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workerId  String   @map("worker_id")
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  siteId    String   @db.Uuid @map("site_id")
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("site_workers")
}

model Attendance {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workerId      String   @map("worker_id")
  worker        Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  siteId        String   @db.Uuid @map("site_id")
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  date          String
  status        String
  overtimeHours Float    @default(0) @map("overtime_hours")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("attendance")
}

model Advance {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workerId  String   @map("worker_id")
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  siteId    String   @db.Uuid @map("site_id")
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(10, 2)
  deducted  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("advances")
}

model Wage {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workerId        String   @map("worker_id")
  worker          Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  siteId          String   @db.Uuid @map("site_id")
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  periodStart     String   @map("period_start")
  periodEnd       String   @map("period_end")
  daysPresent     Float    @map("days_present")
  basicAmount     Decimal  @map("basic_amount") @db.Decimal(10, 2)
  overtimeAmount  Decimal  @map("overtime_amount") @db.Decimal(10, 2)
  advanceDeducted Decimal  @map("advance_deducted") @db.Decimal(10, 2)
  netPayable      Decimal  @map("net_payable") @db.Decimal(10, 2)
  status          String   @default("pending")
  paidAt          DateTime @default(now()) @map("paid_at")

  @@map("wages")
}

model Expense {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId      String   @db.Uuid @map("site_id")
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  category    String
  amount      Decimal  @db.Decimal(12, 2)
  description String
  date        String
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("expenses")
}
